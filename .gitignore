*.key
secrets.*

# Local runtime metrics (written by the app for app_usage.sh)
.llm_usage.json
.ocr_usage.json

# Saved OCR text (holds report text — treat as PHI, never commit)
ocr_cache/

# Data / uploads (avoid committing any medical reports or PHI)
*.pdf
*.csv
*.xlsx
*.docx
uploads/
data/
