# macOS
.DS_Store

# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/

# Virtual environments (incl. custom-named ones: .venv-surya, .venv312, …)
.venv/
.venv*/
venv/
env/
.env
*.env

# Claude Code local settings (machine-specific)
.claude/

